# Sample rcfg-sim per-instance environment file.
# Copy to /etc/rcfg-sim/<LISTEN_IP>.env and customise.
#
# Example: cp rcfg-sim-instance.env.sample /etc/rcfg-sim/10.50.0.1.env
# The instance name in rcfg-sim@<INSTANCE>.service MUST equal LISTEN_IP
# — systemd uses %i to locate this file.
#
# Every value here maps 1:1 to an rcfg-sim flag. No escaping needed unless
# a value contains whitespace or shell metacharacters; in that case quote
# as "value".

# --- Network ---

# IP to bind listeners on. Must be a real interface alias on this host.
# See deploy/ip-aliases.sh for the batched setup helper.
LISTEN_IP=10.50.0.1

# Contiguous TCP port range bound by this instance. PORT_START .. PORT_START + PORT_COUNT - 1.
# Standard layout: 10000..12499 for devices 0..2499 under each IP.
PORT_START=10000
PORT_COUNT=2500

# --- Data ---

# Path to the manifest.csv produced by rcfg-sim-gen. This instance loads the
# rows whose `ip` matches LISTEN_IP and `port` is in this instance's range.
MANIFEST=/opt/rcfg-sim/manifest.csv

# SSH host key. Generated 2048-bit RSA on first run if absent; persisted
# across restarts. Must be writable by the rcfgsim user. Default location is
# /opt/rcfg-sim/host-keys/<LISTEN_IP>.key (per README); /etc/rcfg-sim is also
# in the unit's ReadWritePaths if operators prefer /etc conventions.
HOST_KEY=/opt/rcfg-sim/host-keys/10.50.0.1.key

# --- Credentials ---
# These must match the manifest row credentials so rConfig's polling succeeds.

USERNAME=admin
PASSWORD=admin
ENABLE_PASSWORD=enable123

# --- Metrics ---

# Prometheus HTTP listener for /metrics + /healthz. Use distinct ports across
# instances (e.g. 9100 for 10.50.0.1, 9101 for 10.50.0.2, …). Set empty to
# disable.
METRICS_ADDR=10.50.0.1:9100

# --- Behaviour ---

# Uniform random per-command delay window, in milliseconds. Set both to 0 to
# respond instantly. Production-realistic values are ~50 / 500.
RESPONSE_DELAY_MS_MIN=50
RESPONSE_DELAY_MS_MAX=500

# Per-instance concurrent SSH session cap. At 50k total sessions across 20
# instances, 2500 per instance is the natural cap; double it to 5000 for
# absorbs on polling-burst edges.
MAX_CONCURRENT_SESSIONS=5000

# --- Fault injection (off by default) ---

# Probability [0,1] that an enabled fault fires per event. 0.0 => no faults.
FAULT_RATE=0.0

# Comma-separated fault types. Valid values: auth_fail,disconnect_mid,slow_response,malformed
# Leave empty to disable all injection. FAULT_RATE > 0 without any type is a no-op.
FAULT_TYPES=

# --- Logging ---

# error | warn | info | debug. Info is appropriate for production.
LOG_LEVEL=info
